# Frontend (Vite) — safe to expose (anon key is public by design)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WORKER_URL=            # https://<user>-<space>.hf.space

# Server-side only (Vercel env, never prefixed with VITE_)
SUPABASE_SERVICE_ROLE_KEY=  # for privileged backend writes
ANTHROPIC_API_KEY=          # Claude API — EDL reasoning
WORKER_TOKEN=               # shared secret with the HF render worker
